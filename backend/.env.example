# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=sk-ant-...

# Model for the chat bot. Default is the most capable.
# Switch to claude-haiku-4-5 for cheaper/faster responses if you prefer.
CHAT_MODEL=claude-opus-4-8

# Server
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000

# MongoDB (used to persist contact-form submissions and chat transcripts).
# Leave blank to run without a database (contact submissions are logged only).
MONGODB_URI=
MONGODB_DB=ms_portfolio
