# Copy to .env.local. These are SERVER-side env vars used by the API routes
# (app/api/chat, app/api/contact). Never commit .env.local.

# OpenAI (required for the chat bot)
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-5.4-mini

# MongoDB (optional — used to persist contact-form submissions).
# Leave blank to run without a database (submissions are logged only).
MONGODB_URI=
MONGODB_DB=ms_portfolio
